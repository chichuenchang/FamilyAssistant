{
  "base_currency": "USD",
  "supported_currencies": [
    "CNY",
    "USD",
    "CAD"
  ],
  "categories": {
    "expense": [
      "餐饮",
      "购物",
      "房租",
      "医疗",
      "每月孩子",
      "汽油",
      "水电煤网手机流量",
