# 用户数据目录整体不入库（数据库/凭据/成员注册表/调试日志等，
# 隐私：姓名/法定名/频道 id/账目绝不进 git）
data/

# Python
__pycache__/
*.pyc

# 票据（按月子目录 receipts/YYYY-MM/）
receipts/*
!receipts/.gitkeep

# 文档存档（按类型子目录 documents/<type>/）
documents/*
!documents/.gitkeep

# 防御：OAuth 凭据文件绝不入库（provider 实现只允许用环境变量）
**/Remote_Backup/token*.json
**/Remote_Backup/*secret*
**/Remote_Backup/*.pickle
**/Calendar_Keeper/token*.json
**/Calendar_Keeper/*secret*
**/Calendar_Keeper/*.pickle
client_secret*.json

# IDE
.vscode/
.idea/

# Conda
env/
